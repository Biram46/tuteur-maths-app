# ============================================
# Tuteur Maths App - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# cp .env.local.example .env.local

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=resources

# --- Site URL ---
# Set this to your Render URL in production (e.g. https://your-app.onrender.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- OpenAI ---
OPENAI_API_KEY=your-openai-api-key

# --- Perplexity (AI search) ---
PERPLEXITY_API_KEY=your-perplexity-api-key

# --- DeepSeek (alternative AI) ---
DEEPSEEK_API_KEY=your-deepseek-api-key

# --- ZhipuAI (alternative AI) ---
ZHIPU_API_KEY=your-zhipu-api-key

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Resend (email service for 2FA) ---
RESEND_API_KEY=your-resend-api-key

# --- SymPy API (Python math engine) ---
# URL of the Python/SymPy API for exact math calculations
SYMPY_API_URL=https://tuteur-maths-app.onrender.com

# --- Dev Mode (optional) ---
# NEXT_PUBLIC_DEV_MODE=true

# --- Render.com Deployment ---
# These are automatically set by Render, no need to configure manually:
# RENDER=true
# RENDER_SERVICE_ID=your-render-service-id
# RENDER_INSTANCE_ID=your-render-instance-id
# IS_PULL_REQUEST=false
# RENDER_GIT_BRANCH=main
# RENDER_GIT_COMMIT=sha
# RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
